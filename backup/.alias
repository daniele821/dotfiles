#!/bin/bash

# variables and inits
export FZF_DEFAULT_OPTS='--height=25% --border=rounded'
export STARSHIP_LOG=error
eval "$(zoxide init bash)"

# functions
function clear_zoxide_interactive(){
    zoxide query -ls | fzf -m | while read -r score path; do
        zoxide remove "${path}";
		echo -e "\e[1;33m${path} \e[1;31m(${score})\e[m"
    done;
}
function zoxide_euristically(){
	\cd "$@" &>/dev/null || z "$@" &>/dev/null
}
function zoxide_interactive() {
	\cd "$@" &>/dev/null && return 0
    CHOISES="$(zoxide query -l "$@" | wc -l)" 
    [[ "${CHOISES}" -le "1" ]] && z "$@"
    [[ "${CHOISES}" -gt "1" ]] && zi "$@"
}
function open(){
    nohup xdg-open "${@}" &>/dev/null &
}
function run(){
    nohup "${@}" &>/dev/null & exit 0
}

# aliases
alias la='ls -a'
alias lla='ls -la'
alias ll='ls -l'
alias clear='printf "\033[2J\033[3J\033[1;1H"'
alias cat='bat'
alias zd='clear_zoxide_interactive'
alias cd='zoxide_euristically'
alias ci='zoxide_interactive'

# fixes
bind 'set enable-bracketed-paste on'

# operations to do only on terminal emulators (which support nerd fonts)
if [[ "$(tty)" != /dev/tty* ]]; then
    eval "$(starship init bash)"
    alias ls='lsd --group-dirs first'
    alias tree='lsd --group-dirs first --tree'
fi
